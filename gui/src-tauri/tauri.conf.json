{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentArmor",
  "version": "1.2.0",
  "identifier": "com.agentarmor.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentArmor",
        "width": 1100,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/models", "resources/python"]
  },
  "plugins": {}
}
